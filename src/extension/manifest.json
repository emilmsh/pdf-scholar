{
  "manifest_version": 3,
  "name": "PDF Scholar",
  "short_name": "PDF Scholar",
  "version": "0.11.0",
  "description": "PDF Expert-style leser og annotator — tar over PDF-visning i nettleseren.",
  "minimum_chrome_version": "120",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Åpne PDF i PDF Scholar",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "permissions": ["declarativeNetRequest", "storage", "tabs"],
  "host_permissions": ["http://*/*", "https://*/*", "file:///*"],
  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
