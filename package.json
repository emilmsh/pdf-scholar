{
  "name": "pdfx",
  "productName": "PDF Scholar",
  "version": "0.10.0",
  "description": "A faithful PDF Expert-style PDF reader and annotator for Windows",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite --config vite.web.config.ts",
    "dev:ext": "vite build --watch --config vite.extension.config.ts",
    "build": "electron-vite build",
    "build:ext": "vite build --config vite.extension.config.ts",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.extension.json",
    "sample": "node scripts/make-sample-pdf.mjs",
    "dist": "npm run build && electron-builder --win"
  },
  "author": "Emil Mathias Strøm Halseth",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "mupdf": "1.28.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vite": "^7.3.6"
  }
}
